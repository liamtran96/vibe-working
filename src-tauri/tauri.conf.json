{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Repo Launcher",
  "version": "1.0.0",
  "identifier": "com.repo-launcher.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Repo Launcher",
        "width": 760,
        "height": 820,
        "minWidth": 520,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }}
