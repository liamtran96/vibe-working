{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Working",
  "version": "1.0.0",
  "identifier": "com.vibe-working.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Vibe Working",
        "width": 1000,
        "height": 820,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com https://*.githubusercontent.com; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/liamtran96/vibe-working/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzRjhDRkIyN0Y0RDlGOApSV1Q0MmZRbis0dy9CdnE3emdMbzJBelArQWs3NHJGcTlWYkFmSGNLNzl5dEhVZHhtYzlFWG5MQQo="
    }
  }
}
